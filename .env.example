# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- LLM provider keys (read by the LiteLLM gateway; you only need the ones you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LiteLLM gateway ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-local-dev          # virtual/master key configured in litellm.config.yaml

MODEL_FAST=fast                        # triage / classification (cheap + fast)
MODEL_REASONING=reasoning              # root-cause analysis (stronger)

# --- RAG: Qdrant vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY= 
QDRANT_COLLECTION=sre_runbooks
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Observability: LangSmith (dev/eval loop) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sre-incident-copilot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Observability: Langfuse (self-hosted prod) ---
LANGFUSE_ENABLED=false                 # flip to true once keys are set
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
