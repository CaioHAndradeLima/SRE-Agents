# =============================================================================
# Multi-Agent AI — SRE Incident Copilot :: environment variables
# Copy to .env and fill in. .env is gitignored; .env.example is committed.
# Everything has a sensible local default except the API keys.
# =============================================================================

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- LLM provider keys (read by the LiteLLM gateway; you only need the ones you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LiteLLM gateway (OpenAI-compatible proxy the agents talk to) ---
# Agents never call providers directly; they call this endpoint.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-local-dev          # virtual/master key configured in litellm.config.yaml

# Logical model "tiers" — these are model-group names defined in litellm.config.yaml,
# so the gateway decides the concrete provider/model (cost/latency routing).
MODEL_FAST=fast                        # triage / classification (cheap + fast)
MODEL_REASONING=reasoning              # root-cause analysis (stronger)

# --- RAG: Qdrant vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave empty for local docker
QDRANT_COLLECTION=sre_runbooks
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5 # local fastembed model (no API needed)

# --- Observability: LangSmith (dev/eval loop) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sre-incident-copilot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Observability: Langfuse (self-hosted prod) ---
LANGFUSE_ENABLED=false                 # flip to true once keys are set
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
